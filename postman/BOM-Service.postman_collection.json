          "response": []
        },
        {
          "name": "Agregar Insumo a Producto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Cuero Premium\",\n  \"cantidad\": 2.5,\n  \"unidadDeMedidaId\": 6\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/productos/1/insumos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "productos",
                "1",
                "insumos"
              ]
            },
            "description": "Agrega un insumo a la lista de Bill of Materials de un producto"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Insumos",
      "description": "Operaciones relacionadas con insumos/materiales",
      "item": [
        {
          "name": "Obtener Todos los Insumos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/insumos",
