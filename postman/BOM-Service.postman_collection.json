{
  "info": {
    "_postman_id": "bom-service-collection",
    "name": "BOM Service API",
    "description": "Colección completa de endpoints para probar el microservicio BOM (Bill of Materials)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Productos",
      "description": "Operaciones relacionadas con productos",
      "item": [
        {
          "name": "Crear Producto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreProducto\": \"Zapato Nike Air Max\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/productos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "productos"
              ]
            },
            "description": "Crea un nuevo producto en el sistema"
          },
          "response": []
        },
        {
          "name": "Obtener Todos los Productos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/productos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "productos"
              ]
            },
            "description": "Obtiene la lista completa de todos los productos almacenados en el sistema"
          },
          "response": []
        },
        {
          "name": "Obtener Producto por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/productos/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "productos",
                "1"
              ]
            },
            "description": "Obtiene los detalles de un producto incluyendo su BOM"
